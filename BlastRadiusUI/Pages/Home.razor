@page "/"
@implements IAsyncDisposable
@inject HttpClient Http
@inject IJSRuntime JS
@using Microsoft.AspNetCore.SignalR.Client

<PageTitle>Blast Radius Tool</PageTitle>

<div class="page-shell">

    @* ── Header bar ────────────────────────────────────────────────────── *@
    <header class="header-bar">
        <h1>⚡ Blast Radius Tool</h1>
        <div class="graph-mode-toggle">
            <FluentButton Appearance="@(_filterPanelOpen ? Appearance.Accent : Appearance.Stealth)"
                          Size="ButtonSize.Small"
                          OnClick="@(() => { _filterPanelOpen = !_filterPanelOpen; })"
                          Title="Filter by application">
                ☰ Filter
            </FluentButton>
            <FluentButton Appearance="@(_graphMode == "3d" ? Appearance.Accent : Appearance.Stealth)"
                          OnClick="@(() => SetGraphMode("3d"))"
                          Size="ButtonSize.Small">
                3D
            </FluentButton>
            <FluentButton Appearance="@(_graphMode == "2d" ? Appearance.Accent : Appearance.Stealth)"
                          OnClick="@(() => SetGraphMode("2d"))"
                          Size="ButtonSize.Small">
                2D
            </FluentButton>
        </div>
        <div class="status-group">
            @if (_isConnected)
            {
                <span class="status-badge status-badge--live">
                    <span class="status-dot status-dot--live"></span>
                    LIVE
                </span>
            }
            else
            {
                <span class="status-badge status-badge--disconnected">
                    <span class="status-dot status-dot--disconnected"></span>
                    DISCONNECTED
                </span>
            }
        </div>
    </header>

    @* ── Alert banner (visible only during an active blast radius) ───── *@
    @if (_blastResult is not null)
    {
        <div class="alert-banner">
            <span class="alert-tag">⚠ ALERT</span>
            <span>
                <strong class="alert-failed-node">@_blastResult.FailedNode</strong>
                <span class="muted"> failed &mdash; </span>
                <strong class="alert-affected-count">@_blastResult.AffectedNodes.Count</strong>
                <span class="muted"> downstream service(s) affected</span>
            </span>
            <span class="alert-timestamp">
                @_blastResult.Timestamp.ToString("yyyy-MM-dd HH:mm:ss") UTC
            </span>
        </div>
    }

    @* ── Graph area with side panel ─────────────────────────────────────── *@
    <div class="graph-area">
        <AppFilterPanel Apps="_appNames"
                        SelectedApp="_selectedApp"
                        SelectedAppChanged="OnAppFilterChanged"
                        IsOpen="_filterPanelOpen"
                        IsOpenChanged="@(open => _filterPanelOpen = open)" />
        <div id="graph-container"></div>
    </div>

    @* ── Stats footer ──────────────────────────────────────────────────── *@
    @if (_graphData is not null)
    {
        <footer class="stats-footer">
            <span>Nodes: <strong class="stat-value">@_graphData.Nodes.Count</strong></span>
            <span>Edges: <strong class="stat-value">@_graphData.Edges.Count</strong></span>
            @if (_blastResult is not null)
            {
                <span>
                    Affected: <strong class="stat-value--alert">@_blastResult.AffectedNodes.Count</strong>
                </span>
                <span class="stat-origin">
                    Origin: <strong class="stat-value--origin">@_blastResult.FailedNode</strong>
                </span>
            }
        </footer>
    }
</div>

@code {
    // ── Private state ──────────────────────────────────────────────────
    private IJSObjectReference? _jsModule;
    private HubConnection? _hubConnection;
    private GraphData? _graphData;
    private BlastRadiusResult? _blastResult;
    private bool _isConnected;
    private bool _graphInitialized;
    private string _graphMode = "3d";
    private List<ApplicationInfo> _appNames = new();
    private string? _selectedApp;
    private bool _filterPanelOpen;

    // ── Lifecycle: load data and set up SignalR ─────────────────────────
    protected override async Task OnInitializedAsync()
    {
        // 1. Fetch the full dependency graph (read-only — invariant 8).
        try
        {
            _graphData = await Http.GetFromJsonAsync<GraphData>("/api/graph");

            if (_graphData is not null)
            {
                _appNames = _graphData.Applications?.OrderBy(a => a.Id).ToList() ?? new();
            }
        }
        catch (Exception ex)
        {
            System.Console.Error.WriteLine($"Failed to load graph: {ex.Message}");
        }

        // 2. Fetch the latest blast result (may be 204 No Content).
        try
        {
            var response = await Http.GetAsync("/api/blast_result");
            if (response.IsSuccessStatusCode
                && response.StatusCode != System.Net.HttpStatusCode.NoContent)
            {
                _blastResult = await response.Content.ReadFromJsonAsync<BlastRadiusResult>();
            }
        }
        catch (Exception ex)
        {
            System.Console.Error.WriteLine($"Failed to load blast result: {ex.Message}");
        }

        // 3. SignalR real-time connection (non-fatal if it fails — invariant 7 spirit).
        await ConnectSignalRAsync();
    }

    // ── Lifecycle: first render triggers JS interop ─────────────────────
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_graphInitialized || _graphData is null) return;
        _graphInitialized = true;

        _jsModule = await JS.InvokeAsync<IJSObjectReference>("import", "./js/graph.js");
        await _jsModule.InvokeVoidAsync("initGraph", "graph-container", _graphData, _graphMode);

        // If a blast result was already loaded, highlight it immediately.
        if (_blastResult is not null)
        {
            await _jsModule.InvokeVoidAsync("highlightBlastRadius", _blastResult);
        }
    }

    // ── SignalR ─────────────────────────────────────────────────────────
    private async Task ConnectSignalRAsync()
    {
        try
        {
            var negotiate = await Http.GetFromJsonAsync<SignalRNegotiateResponse>(
                "/api/signalr_negotiate");

            if (negotiate is null) return;

            _hubConnection = new HubConnectionBuilder()
                .WithUrl(negotiate.Url, options =>
                {
                    options.AccessTokenProvider =
                        () => Task.FromResult<string?>(negotiate.AccessToken);
                    options.SkipNegotiation = true;
                    options.Transports =
                        Microsoft.AspNetCore.Http.Connections.HttpTransportType.WebSockets;
                })
                .WithAutomaticReconnect()
                .Build();

            _hubConnection.On<BlastRadiusResult>("blastRadius", OnBlastRadiusReceived);

            await _hubConnection.StartAsync();
            _isConnected = true;
        }
        catch (Exception ex)
        {
            System.Console.Error.WriteLine(
                $"SignalR connection failed (non-fatal): {ex.Message}");
            _isConnected = false;
        }
    }

    private async Task OnBlastRadiusReceived(BlastRadiusResult result)
    {
        _blastResult = result;

        // StateHasChanged must be dispatched on the render thread.
        await InvokeAsync(StateHasChanged);

        if (_jsModule is not null)
        {
            await _jsModule.InvokeVoidAsync("highlightBlastRadius", result);
        }
    }

    // ── Graph mode toggle ────────────────────────────────────────────────
    private async Task SetGraphMode(string mode)
    {
        if (mode == _graphMode || _jsModule is null) return;
        _graphMode = mode;
        await _jsModule.InvokeVoidAsync("toggleMode", mode);
    }

    // ── App filter ────────────────────────────────────────────────────────
    private async Task OnAppFilterChanged(string? appName)
    {
        _selectedApp = appName;
        if (_jsModule is null) return;

        if (appName is null)
        {
            await _jsModule.InvokeVoidAsync("clearAppFilter");
        }
        else
        {
            var nodeIds = _graphData!.Nodes
                .Where(n => n.AppIds.Contains(appName))
                .Select(n => n.Id)
                .ToList();
            await _jsModule.InvokeVoidAsync("highlightApp", appName, nodeIds);
        }
    }

    // ── Cleanup ─────────────────────────────────────────────────────────
    public async ValueTask DisposeAsync()
    {
        if (_hubConnection is not null)
        {
            await _hubConnection.DisposeAsync();
        }

        if (_jsModule is not null)
        {
            try
            {
                await _jsModule.InvokeVoidAsync("disposeGraph");
            }
            catch (JSDisconnectedException)
            {
                // Circuit already torn down — nothing to clean up.
            }

            await _jsModule.DisposeAsync();
        }
    }
}
