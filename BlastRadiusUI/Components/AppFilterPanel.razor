@using Microsoft.FluentUI.AspNetCore.Components

<div class="app-filter-panel @(IsOpen ? "" : "app-filter-panel--closed")">
    <div class="app-filter-header">
        <span class="app-filter-title">Applications</span>
        <FluentButton Appearance="Appearance.Stealth"
                      Size="ButtonSize.Small"
                      OnClick="@(() => IsOpenChanged.InvokeAsync(false))"
                      Title="Close panel">
            ✕
        </FluentButton>
    </div>
    <div class="app-filter-list">
        <FluentButton Appearance="@(SelectedApp is null ? Appearance.Accent : Appearance.Stealth)"
                      Style="width:100%; justify-content:flex-start;"
                      OnClick="@(() => SelectedAppChanged.InvokeAsync(null))">
            All Applications
        </FluentButton>
        @foreach (var app in Apps)
        {
            var currentApp = app;
            <FluentButton Appearance="@(SelectedApp == currentApp ? Appearance.Accent : Appearance.Stealth)"
                          Style="width:100%; justify-content:flex-start; text-transform:capitalize;"
                          OnClick="@(() => SelectedAppChanged.InvokeAsync(currentApp))">
                @currentApp
            </FluentButton>
        }
    </div>
</div>

@code {
    [Parameter] public List<string> Apps { get; set; } = new();
    [Parameter] public string? SelectedApp { get; set; }
    [Parameter] public EventCallback<string?> SelectedAppChanged { get; set; }
    [Parameter] public bool IsOpen { get; set; }
    [Parameter] public EventCallback<bool> IsOpenChanged { get; set; }
}
